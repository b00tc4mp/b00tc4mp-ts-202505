{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start-watch": "node --env-file=.env --watch build",
    "start-inspect": "node --env-file=.env --inspect-brk build",
    "compile-watch": "tsc --watch",
    "test": "mocha --require tsx --extensions ts 'src/**/*.spec.ts'",
    "test-watch": "mocha --require tsx --extensions ts --watch 'src/**/*.spec.ts'",
    "test-inspect": "mocha --require tsx --extensions ts --inspect-brk 'src/**/*.spec.ts'",
    "seed": "tsx src/scripts/seedData.ts",
    "type-check": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.ts'",
    "validate": "npm run type-check && npm run format:check && npm run lint && npm run test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/chai": "^5.2.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "chai": "^6.2.1",
    "eslint": "^9.39.1",
    "mocha": "^11.7.5",
    "prettier": "^3.7.4",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
